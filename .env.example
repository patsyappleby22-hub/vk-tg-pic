# ──────────────────────────────────────────────────────────────────────────────
# Telegram Bot (опционально — можно запустить только VK или только Telegram)
# ──────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ──────────────────────────────────────────────────────────────────────────────
# VK Bot (опционально — можно запустить только VK или только Telegram)
# ──────────────────────────────────────────────────────────────────────────────
VK_BOT_TOKEN=your_vk_community_token_here

# ──────────────────────────────────────────────────────────────────────────────
# Google Cloud / Vertex AI
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# Optional Settings
# ──────────────────────────────────────────────────────────────────────────────
# MAX_CONCURRENT_REQUESTS=3
# LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Persistent Storage (укажи путь к смонтированному тому — Northflank/Cloud Run)
# ──────────────────────────────────────────────────────────────────────────────
# SETTINGS_FILE=/persistent/user_settings.json
# API_KEYS_FILE=/persistent/api_keys.json
